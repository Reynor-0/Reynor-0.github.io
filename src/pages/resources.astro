---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const groups = [
	{ name: '工具链', links: [{ label: 'Astro', href: '/resources/astro/' }, { label: 'GitHub Actions', href: '/resources/github-actions/' }, { label: 'V4L2 Tools', href: '/resources/v4l2-tools/' }] },
	{ name: '图像处理', links: [{ label: 'OpenCV', href: '/resources/opencv/' }, { label: 'RawPy', href: '/resources/rawpy/' }, { label: 'Color Science', href: '/resources/color-science/' }] },
	{ name: 'Linux 多媒体', links: [{ label: 'Linux Media API', href: '/resources/linux-media-api/' }, { label: 'v4l2loopback', href: '/resources/v4l2loopback/' }, { label: 'FFmpeg', href: '/resources/ffmpeg/' }] },
	{ name: '写作规范', links: [{ label: 'Markdown', href: '/resources/markdown/' }, { label: '资源目录', href: '/resources/asset-layout/' }, { label: '发布检查清单', href: '/resources/release-checklist/' }] },
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`资源 - ${SITE_TITLE}`} description="工具链、链接、配置和资料索引。" />
	</head>
	<body>
		<Header />
		<main class="resources-page">
			<nav class="crumb"><a href="/">主页</a><span>〉</span><strong>资源</strong></nav>
			<section class="hero">
				<p class="eyebrow">Resources</p>
				<h1>资源</h1>
				<p>资源栏目适合做分类索引，不一定每条都需要详情页。</p>
			</section>
			<section class="resource-grid">
				{
					groups.map((group) => (
						<article>
							<h2>{group.name}</h2>
							<ul>
								{group.links.map((link) => (
									<li><a href={link.href}>{link.label}</a></li>
								))}
							</ul>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.resources-page { width: min(100% - 32px, 1040px); }
	.crumb { display: flex; gap: 0.35rem; margin-bottom: 20px; color: rgb(var(--muted)); font-size: 0.92rem; }
	.hero { max-width: 720px; margin-bottom: 28px; }
	.eyebrow { margin-bottom: 0.25rem; color: var(--accent-strong); font-weight: 800; text-transform: uppercase; }
	.hero p { color: rgb(var(--muted)); }
	.resource-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
	.resource-grid article { padding: 1.25rem; border: 1px solid rgba(var(--line), 0.9); border-radius: 8px; background: rgba(255, 255, 255, 0.84); box-shadow: 0 8px 24px rgba(39, 45, 52, 0.05); }
	.resource-grid h2 { font-size: 1.16rem; }
	.resource-grid ul { display: grid; gap: 8px; margin: 0; padding: 0; list-style: none; }
	.resource-grid a { display: block; padding: 0.55rem 0.65rem; border-radius: 8px; background: rgba(var(--soft), 0.9); color: rgb(var(--ink)); }
	.resource-grid a:hover { background: #eaf3ff; color: var(--accent-strong); }
	@media (max-width: 760px) { .resource-grid { grid-template-columns: 1fr; } }
</style>
