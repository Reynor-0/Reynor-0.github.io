---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projects = [
	{
		name: 'V4L2 Camera Pipeline Demo',
		href: '/projects/v4l2-camera-pipeline/',
		status: '进行中',
		summary: '从采集、缓冲、ISP 处理到虚拟摄像头输出的端到端实验。',
		stack: ['V4L2', 'C++', 'ISP', 'Linux'],
	},
	{
		name: 'Demosaic Algorithm Notes',
		href: '/projects/demosaic-algorithm-notes/',
		status: '整理中',
		summary: '围绕 Bayer RAW 到 RGB 的插值、边缘感知和质量评估做实验记录。',
		stack: ['Image Processing', 'Python', 'OpenCV'],
	},
	{
		name: 'Personal Blog System',
		href: '/projects/personal-blog-system/',
		status: '迭代中',
		summary: '基于 Astro 的个人知识库，关注内容结构、资源管理和发布流程。',
		stack: ['Astro', 'GitHub Pages', 'Content'],
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`项目 - ${SITE_TITLE}`} description="项目复盘、实验记录和 Demo 汇总。" />
	</head>
	<body>
		<Header />
		<main class="section-page">
			<nav class="crumb"><a href="/">主页</a><span>〉</span><strong>项目</strong></nav>
			<section class="hero">
				<p class="eyebrow">Projects</p>
				<h1>项目</h1>
				<p>项目栏目更像作品集和复盘区，适合展示目标、技术栈、当前状态、截图和仓库链接。</p>
			</section>
			<section class="project-grid">
				{
					projects.map((project) => (
						<a class="project-card" href={project.href}>
							<div>
								<span class="status">{project.status}</span>
								<h2>{project.name}</h2>
								<p>{project.summary}</p>
							</div>
							<ul>
								{project.stack.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.section-page { width: min(100% - 32px, 1080px); }
	.crumb { display: flex; gap: 0.35rem; margin-bottom: 20px; color: rgb(var(--muted)); font-size: 0.92rem; }
	.hero { max-width: 760px; margin-bottom: 28px; }
	.eyebrow { margin-bottom: 0.25rem; color: var(--accent-strong); font-weight: 800; text-transform: uppercase; }
	.hero p { color: rgb(var(--muted)); }
	.project-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
	.project-card { display: flex; flex-direction: column; justify-content: space-between; min-height: 280px; padding: 1.25rem; border: 1px solid rgba(var(--line), 0.9); border-radius: 8px; background: rgba(255, 255, 255, 0.84); box-shadow: 0 8px 24px rgba(39, 45, 52, 0.05); color: rgb(var(--ink)); }
	.project-card:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
	.status { display: inline-block; margin-bottom: 1rem; padding: 0.18rem 0.55rem; border-radius: 999px; background: #eaf3ff; color: var(--accent-strong); font-size: 0.82rem; font-weight: 800; }
	.project-card h2 { font-size: 1.22rem; }
	.project-card p { color: rgb(var(--muted)); font-size: 0.95rem; }
	.project-card ul { display: flex; flex-wrap: wrap; gap: 8px; margin: 1rem 0 0; padding: 0; list-style: none; }
	.project-card li { padding: 0.16rem 0.45rem; border: 1px solid rgb(var(--line)); border-radius: 999px; color: rgb(var(--muted)); font-size: 0.8rem; }
	@media (max-width: 900px) { .project-grid { grid-template-columns: 1fr; } }
</style>
