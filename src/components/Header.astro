---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const searchEntries = posts.map((post) => ({
	title: post.data.title,
	description: post.data.description,
	url: `/blog/${post.id}/`,
}));
---

<header class="site-header">
	<nav class="nav-shell" aria-label="Primary navigation">
		<a class="brand" href="/">
			<span class="brand-mark">R</span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">主页</HeaderLink>
			<HeaderLink href="/blog">技术</HeaderLink>
			<HeaderLink href="/projects">项目</HeaderLink>
			<HeaderLink href="/reading">阅读</HeaderLink>
			<HeaderLink href="/notes">随笔</HeaderLink>
			<HeaderLink href="/resources">资源</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
		<div class="search" data-search-root>
			<label class="sr-only" for="site-search">搜索文章</label>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
				<path
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="m21 21-4.34-4.34m1.34-5.66a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"
				/>
			</svg>
			<input id="site-search" data-search-input type="search" placeholder="查找" autocomplete="off" />
			<kbd>Ctrl K</kbd>
			<div class="search-results" data-search-results hidden></div>
		</div>
		<a class="github-link" href="https://github.com/Reynor-0/Reynor-0.github.io" target="_blank" rel="noreferrer">
			<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18">
				<path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.5 7.5 0 0 1 8 3.36c.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
				/>
			</svg>
			<span>GitHub</span>
		</a>
	</nav>
</header>

<script define:vars={{ searchEntries }}>
	const root = document.querySelector('[data-search-root]');
	const input = document.querySelector('[data-search-input]');
	const results = document.querySelector('[data-search-results]');

	function closeResults() {
		if (results) {
			results.hidden = true;
			results.innerHTML = '';
		}
	}

	function renderResults(query) {
		if (!results) return;
		const normalized = query.trim().toLowerCase();
		if (!normalized) {
			closeResults();
			return;
		}

		const matches = searchEntries
			.filter((entry) => `${entry.title} ${entry.description}`.toLowerCase().includes(normalized))
			.slice(0, 6);

		if (matches.length === 0) {
			const empty = document.createElement('p');
			empty.textContent = '没有找到相关文章';
			results.replaceChildren(empty);
			results.hidden = false;
			return;
		}

		const nodes = matches.map((entry) => {
			const link = document.createElement('a');
			const title = document.createElement('strong');
			const description = document.createElement('span');
			link.href = entry.url;
			title.textContent = entry.title;
			description.textContent = entry.description;
			link.append(title, description);
			return link;
		});
		results.replaceChildren(...nodes);
		results.hidden = false;
	}

	input?.addEventListener('input', (event) => {
		renderResults(event.currentTarget.value);
	});

	input?.addEventListener('keydown', (event) => {
		if (event.key === 'Enter') {
			const first = results?.querySelector('a');
			if (first) window.location.href = first.href;
		}
		if (event.key === 'Escape') {
			closeResults();
			input.blur();
		}
	});

	document.addEventListener('keydown', (event) => {
		if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
			event.preventDefault();
			input?.focus();
		}
	});

	document.addEventListener('click', (event) => {
		if (root && !root.contains(event.target)) closeResults();
	});
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid rgba(var(--line), 0.78);
		background: rgba(255, 255, 255, 0.86);
		backdrop-filter: blur(14px);
	}

	.nav-shell {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(100% - 32px, 1320px);
		height: 66px;
		margin: 0 auto;
		gap: 20px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 11px;
		color: rgb(var(--ink));
		font-size: 1.05rem;
		font-weight: 800;
		white-space: nowrap;
	}

	.brand-mark {
		display: inline-grid;
		width: 30px;
		height: 30px;
		place-items: center;
		border-radius: 50%;
		background: linear-gradient(135deg, #4389bd, #9cc7da);
		color: #fff;
		font-size: 0.9rem;
		box-shadow: 0 8px 20px rgba(67, 137, 189, 0.24);
	}

	.nav-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		flex: 1;
	}

	.search {
		position: relative;
		display: flex;
		align-items: center;
		gap: 8px;
		width: min(260px, 24vw);
		height: 36px;
		padding: 0 10px;
		border: 1px solid rgba(var(--line), 0.88);
		border-radius: 8px;
		background: rgba(244, 246, 248, 0.92);
		color: rgb(var(--muted));
	}

	.search input {
		min-width: 0;
		flex: 1;
		border: 0;
		outline: 0;
		background: transparent;
		color: rgb(var(--ink));
		font: inherit;
		font-size: 0.92rem;
	}

	.search kbd {
		padding: 0.08rem 0.35rem;
		border: 1px solid rgba(var(--line), 1);
		border-radius: 5px;
		background: #fff;
		color: rgb(var(--muted));
		font-size: 0.75rem;
		font-family: inherit;
		white-space: nowrap;
	}

	.search-results {
		position: absolute;
		top: calc(100% + 8px);
		right: 0;
		z-index: 20;
		width: min(420px, calc(100vw - 32px));
		padding: 8px;
		border: 1px solid rgba(var(--line), 0.95);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.98);
		box-shadow: var(--shadow);
	}

	.search-results a,
	.search-results p {
		display: block;
		margin: 0;
		padding: 0.65rem 0.7rem;
		border-radius: 8px;
		color: rgb(var(--ink));
	}

	.search-results a:hover {
		background: #eef6ff;
	}

	.search-results strong,
	.search-results span {
		display: block;
	}

	.search-results strong {
		font-size: 0.92rem;
		line-height: 1.35;
	}

	.search-results span,
	.search-results p {
		color: rgb(var(--muted));
		font-size: 0.82rem;
		line-height: 1.45;
	}

	.github-link {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		color: rgb(var(--ink));
		font-size: 0.9rem;
	}

	.github-link:hover {
		color: var(--accent-strong);
	}

	@media (max-width: 720px) {
		.nav-shell {
			width: min(100% - 20px, 1320px);
			height: auto;
			padding: 12px 0;
			flex-wrap: wrap;
			gap: 10px;
		}

		.nav-links {
			order: 3;
			width: 100%;
			justify-content: flex-start;
			overflow-x: auto;
		}

		.github-link span {
			display: none;
		}

		.search {
			order: 2;
			width: calc(100% - 42px);
			flex: 1;
		}

		.search kbd {
			display: none;
		}
	}
</style>
