---
const today = new Date();
---

<footer>
	<div class="footer-shell">
		<p>Copyright © {today.getFullYear()} Reynor-0</p>
		<div class="footer-links">
			<a href="https://github.com/Reynor-0" target="_blank" rel="noreferrer">GitHub</a>
			<a href="/rss.xml">RSS</a>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid rgba(var(--line), 0.9);
		background: rgba(246, 248, 251, 0.88);
		color: rgb(var(--muted));
	}

	.footer-shell {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(100% - 32px, 1180px);
		margin: 0 auto;
		padding: 26px 0;
		gap: 16px;
		font-size: 0.92rem;
	}

	p {
		margin: 0;
	}

	.footer-links {
		display: flex;
		gap: 16px;
	}

	.footer-links a {
		color: rgb(var(--muted));
	}

	.footer-links a:hover {
		color: rgb(var(--ink));
	}

	@media (max-width: 560px) {
		.footer-shell {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
